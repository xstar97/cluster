{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": ["Block automerge for minecraft-java patch"],
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "matchPackageNames": ["ghcr.io/itzg/minecraft-server"],
      "labels": ["type/patch", "system-upgrade"],
      "addLabels": null
    },
    {
      "description": ["Block automerge for minecraft-java minor"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "matchPackageNames": ["ghcr.io/itzg/minecraft-server"],
      "labels": ["type/minor", "system-upgrade"],
      "addLabels": null
    },
    {
      "description": ["Block automerge for minecraft-java major"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "matchPackageNames": ["ghcr.io/itzg/minecraft-server"],
      "labels": ["type/major", "system-upgrade"],
      "addLabels": null
    }
  ]
  }